---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) =>
  import.meta.env.DEV || !data.draft
);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Writing" description="All posts on distributed data systems, engineering, and infrastructure.">
  <h1>Writing</h1>

  {posts.length === 0 ? (
    <p><em>Nothing published yet, first post coming soon.</em></p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          {post.data.draft && <span class="tag">draft</span>}
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
